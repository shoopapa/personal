# Test environment — used by developers locally and in CI.
# CI overrides DATABASE_URL via the workflow env block (postgres service on port 5432).
# Locally this file is loaded as-is, pointing at the dev postgres on port 5100.

DATABASE_URL="postgres://postgres:postgres@localhost:5100/postgres?sslmode=disable"
TZ=UTC

AUTH_SECRET="ci-e2e-auth-secret-minimum-32-chars"

AWS_REGION=us-east-1
S3_MEDIA_BUCKET=test-bucket
S3_ENDPOINT=http://localhost:4566

# External services — mocked in e2e tests, no real emails/SMS sent
COMMUNICATION_MOCK=true
TWILIO_ACCOUNT_SID=test-sid
TWILIO_AUTH_TOKEN=test-token
NEXT_PUBLIC_CAPTCHA_SITE_KEY=test-captcha-site-key
CAPTCHA_SECRET_KEY=test-captcha-secret
BETTER_AUTH_SECRET=test-better-auth-secret
# Intentionally unset — getBaseUrl() falls back to http://localhost:PORT for tests
# NEXT_PUBLIC_APP_API_URL=
SES_IDENITY=lightninglms.com

SCORM_CLOUD_APP_ID=test
SCORM_CLOUD_SECRET_KEY=test
SCORM_CLOUD_API_URL=https://test.cloud.scorm.com/api/v2